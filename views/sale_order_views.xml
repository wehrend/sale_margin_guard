<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_order_form_inherit_margin_guard" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.margin.guard</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='action_confirm'][1]" position="before">
                    <button name="action_approve_margin"
                            string="Approve Margin"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'to_approve'"
                            groups="sales_team.group_sale_manager"/>
                </xpath>

                <xpath expr="//field[@name='state']" position="attributes">
                    <attribute name="statusbar_visible">draft,sent,to_approve,sale</attribute>
                </xpath>

                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="margin_alert" invisible="1"/>
                    <div class="alert alert-danger" role="alert" invisible="not margin_alert" style="margin-bottom: 15px;">
                        <strong>Margin Warning:</strong> The profit margin of this order is below the minimum threshold. Confirmation requires manager approval!
                    </div>
                </xpath>

            </field>
        </record>

        <record id="view_quotation_list_inherit_margin_guard" model="ir.ui.view">
            <field name="name">sale.order.list.inherit.margin.guard</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-danger">margin_alert == True</attribute>
                </xpath>
                <xpath expr="//field[@name='state']" position="before">
                    <field name="margin_alert" column_invisible="True"/>
                </xpath>
            </field>
        </record>

        <record id="view_order_list_inherit_margin_guard" model="ir.ui.view">
            <field name="name">sale.order.list.order.inherit.margin.guard</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-danger">margin_alert == True</attribute>
                </xpath>
                <xpath expr="//field[@name='state']" position="before">
                    <field name="margin_alert" column_invisible="True"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>